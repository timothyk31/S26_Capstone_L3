        "test -f /etc/pam.d/password-auth && echo \"FILE_EXISTS\" || echo \"FILE_NOT_FOUND\"",
        "rpm -q kernel-core && echo \"KERNEL_INSTALLED\" || echo \"KERNEL_NOT_INSTALLED\"",
        "ls -l /usr/bin/authselect 2>/dev/null || echo \"AUTHSELECT_NOT_FOUND\"",
        "cat /etc/pam.d/password-auth 2>/dev/null || echo \"FILE_NOT_FOUND\"",
        "which authselect",
        "cat /etc/pam.d/password-auth | grep -i faillock",
        "grep -i faillock /etc/pam.d/password-auth || echo \"FAILLOCK_NOT_FOUND\"",
        "test -f /etc/pam.d/password-auth && echo \"FILE_EXISTS\" || echo \"FILE_NOT_FOUND\"",
        "head -5 /etc/pam.d/password-auth",
        "sed -i '/^auth.*required.*pam_deny.so/i auth        required       pam_faillock.so' /etc/pam.d/password-auth",
        "sed -i '/^account.*required.*pam_deny.so/i account     required       pam_faillock.so' /etc/pam.d/password-auth",
        "grep -E '(auth|account).*required.*pam_faillock.so' /etc/pam.d/password-auth",
        "grep -n pam_faillock /etc/pam.d/password-auth"
